DATABASE_URL="postgresql://postgres:postgres@localhost:5432/camob"

# Required in production. Generate a long random string (e.g. `openssl rand -hex 32`).
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Admin login.
ADMIN_EMAIL="admin@camobresidence.com"
# Required in production. Generate with: npm run hash:password <password>
# Format: <salt>:<scrypt-hash>
ADMIN_PASSWORD_HASH=""
# Plaintext fallback for local dev only. Ignored when NODE_ENV=production.
ADMIN_PASSWORD="change-me"

SEED_DEMO_DATA="false"

# Payments.
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# Email (Resend). If unset, booking notifications only log to NotificationLog.
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="reservations@camobresidence.com"
BOOKING_ALERT_EMAIL="camobresidence@gmail.com"

# Map (optional — Google Maps embed works without an API key).
NEXT_PUBLIC_MAPBOX_TOKEN=""
