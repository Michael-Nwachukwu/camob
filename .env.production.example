# Copy to .env.production on the server and fill in real values.
# The app refuses to boot in production if the starred (*) values are missing
# or left at their dev defaults — that's instrumentation.ts doing its job.

# ── Domain (used by Caddy for automatic HTTPS) ──
DOMAIN="camobresidence.com"

# ── Database (the `db` service in docker-compose) ──
# POSTGRES_PASSWORD is also read by the db container. Keep them in sync.
POSTGRES_PASSWORD="change-this-to-a-long-random-string"
DATABASE_URL="postgresql://camob:change-this-to-a-long-random-string@db:5432/camob"

# ── Auth (*) ──
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://camobresidence.com"
ADMIN_EMAIL="admin@camobresidence.com"
# Generate: npm run hash:password 'your-password'  (run locally, paste the hash)
ADMIN_PASSWORD_HASH=""

# ── Cron (used by the cron sidecar to authenticate to /api/cron/expire-holds) ──
# Generate: openssl rand -hex 32
CRON_SECRET=""

# ── Guest booking lookup links (optional; defaults to NEXTAUTH_SECRET) ──
BOOKING_LOOKUP_SECRET=""

# ── Payments (Paystack) ──
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_WEBHOOK_SECRET=""

# ── Email (Resend — optional; without it, notifications only log to the DB) ──
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="reservations@camobresidence.com"
BOOKING_ALERT_EMAIL="camobresidence@gmail.com"
